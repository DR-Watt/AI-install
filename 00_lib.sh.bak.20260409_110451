# apt_install: egyszerű apt telepítés logba, progress nélkül (backward compat)
apt_install() {
  DEBIAN_FRONTEND=noninteractive sudo_run apt-get install -y -qq \
    -o Dpkg::Options::="--force-confdef" \
    -o Dpkg::Options::="--force-confold" \
    "$@" >> "$LOGFILE_AI" 2>&1
}
